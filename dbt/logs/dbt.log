[0m14:26:41.621704 [debug] [Thread-1 (]: On model.lab5_bi.stg_order_date: /* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "lab5_bi", "target_name": "dev", "node_id": "model.lab5_bi.stg_order_date"} */
USE [Lab5_BI];
    
    

    

    
    USE [Lab5_BI];
    EXEC('
        create view "Staging_Staging"."stg_order_date__dbt_tmp" as 

with sales_dates as (
    select
        cast(dateadd(year, 11, cast(OrderDate as date)) as date) as order_date
    from "Lab5_BI"."Extract"."SalesOrderHeader"
),
bounds as (
    select
        min(order_date) as min_order_date,
        max(order_date) as max_order_date
    from sales_dates
),
calendar as (
    select min_order_date as date_value
    from bounds
    union all
    select dateadd(day, 1, date_value)
    from calendar c
    cross join bounds b
    where c.date_value < b.max_order_date
)
select
    cast(format(date_value, ''yyyyMMdd'') as int) as date_key,
    cast(date_value as date) as order_date,
    day(date_value) as day_of_month,
    month(date_value) as month_number,
    datename(month, date_value) as month_name,
    datepart(quarter, date_value) as quarter_number,
    case
        when month(date_value) between 1 and 6 then 1
        else 2
    end as half_year,
    year(date_value) as calendar_year,
    datename(weekday, date_value) as weekday_name,
    datepart(weekday, date_value) as weekday_number
from calendar
